# Build artefacts – largest directory, never needed in the image
target/

# Git history
.git/
.gitignore

# Editor / IDE
.idea/
.vscode/
*.iml

# Claude Code session data
.claude/

# Persistent runtime data (mounted as a volume at /data)
data/

# Docker files themselves
Dockerfile
docker-compose.yml
.dockerignore

# Docs / misc
*.md
LICENSE

# …except the changelog: src/site/changelog.rs `include_str!`s it, so it is a
# build input, not a doc. Without this the release build fails to compile.
!CHANGELOG.md
